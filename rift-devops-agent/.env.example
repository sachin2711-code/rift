# RIFT DevOps Agent - Environment Variables

# =============================================================================
# API Keys (Required)
# =============================================================================

# OpenAI API Key for LLM-powered fix generation
OPENAI_API_KEY=sk-your-openai-api-key-here

# GitHub Personal Access Token for repository operations
GITHUB_TOKEN=ghp_your-github-token-here

# =============================================================================
# Application Settings
# =============================================================================

# Debug mode (true/false)
DEBUG=false

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# =============================================================================
# Agent Configuration
# =============================================================================

# Maximum CI/CD retry iterations
MAX_ITERATIONS=5

# Delay between CI/CD status checks (seconds)
RETRY_DELAY_SECONDS=30

# Sandbox timeout for code execution (seconds)
SANDBOX_TIMEOUT=300

# =============================================================================
# Database Configuration
# =============================================================================

# SQLite database URL
DATABASE_URL=sqlite:///./rift_agent.db

# ChromaDB persistence path
CHROMA_DB_PATH=./chroma_db

# =============================================================================
# Vector Database (Optional - for cloud deployment)
# =============================================================================

# Vector DB type: chromadb or pinecone
VECTOR_DB_TYPE=chromadb

# Pinecone settings (only if using Pinecone)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=rift-devops-agent

# =============================================================================
# Frontend Configuration
# =============================================================================

# API URL for frontend
VITE_API_URL=http://localhost:8000

# =============================================================================
# Notifications (Optional)
# =============================================================================

# Slack webhook URL for notifications
SLACK_WEBHOOK_URL=

# Discord webhook URL for notifications
DISCORD_WEBHOOK_URL=

# =============================================================================
# GitHub Configuration
# =============================================================================

# GitHub username for commits
GITHUB_USERNAME=

# Git email for commits
GITHUB_EMAIL=rift-agent@example.com

# =============================================================================
# LLM Configuration
# =============================================================================

# LLM model to use
LLM_MODEL=gpt-4-turbo-preview

# LLM temperature (0.0 - 1.0)
LLM_TEMPERATURE=0.1
